    {
      "parameters": {
        "jsCode": "const exceptions = $input.first().json.exceptions || [];\nconst totalExceptions = exceptions.length;\nconst highSeverity = exceptions.filter(e => e.Severity === \"High\").length;\nconst mediumSeverity = exceptions.filter(e => e.Severity === \"Medium\").length;\nconst lowSeverity = exceptions.filter(e => e.Severity === \"Low\").length;\nconst missingInSQL = exceptions.filter(e => e.ExceptionType === \"MISSING_IN_SQL_SERVER\").length;\nconst missingInExcel = exceptions.filter(e => e.ExceptionType === \"MISSING_IN_EXCEL\").length;\nconst quantityMismatch = exceptions.filter(e => e.ExceptionType === \"QUANTITY_MISMATCH\").length;\nconst priceMismatch = exceptions.filter(e => e.ExceptionType === \"PRICE_MISMATCH\").length;\nconst netAmountMismatch = exceptions.filter(e => e.ExceptionType === \"NET_AMOUNT_MISMATCH\").length;\nconst duplicateCount = exceptions.filter(e => e.ExceptionType === \"DUPLICATE_TRADE\").length;\nconst invalidSQL = exceptions.filter(e => e.ExceptionType === \"INVALID_SQL_RECORD\").length;\nconst invalidExcel = exceptions.filter(e => e.ExceptionType === \"INVALID_EXCEL_RECORD\").length;\nconst runDate = new Date().toISOString().split(\"T\")[0];\nconst tradeDate = new Date(Date.now() - 86400000).toISOString().split(\"T\")[0];\n\nconst validSQLCount = $(\"Filter Valid SQL Records\").all().length;\nconst validExcelCount = $(\"Filter Valid Excel Records\").all().length;\nconst totalTradesReviewed = validSQLCount + validExcelCount;\n\nconst unmatchedTrades = missingInSQL + missingInExcel;\nconst mismatchCount = quantityMismatch + priceMismatch + netAmountMismatch;\nconst matchedTrades = Math.max(0, totalTradesReviewed - totalExceptions);\nconst status = totalExceptions === 0 ? \"Completed Successfully\" : \"Completed With Exceptions\";\nconst reportPath = \"/data/reports/Reconciliation_Exception_Report_\" + tradeDate.replace(/-/g, \"\") + \".xlsx\";\n\nreturn [{\n  json: {\n    ReconciliationDate: runDate,\n    TradeDate: tradeDate,\n    TotalTradesReviewed: totalTradesReviewed,\n    MatchedTrades: matchedTrades,\n    UnmatchedTrades: unmatchedTrades,\n    MismatchCount: mismatchCount,\n    DuplicateCount: duplicateCount,\n    TotalExceptions: totalExceptions,\n    HighSeverityExceptions: highSeverity,\n    MediumSeverityExceptions: mediumSeverity,\n    LowSeverityExceptions: lowSeverity,\n    Status: status,\n    ReportPath: reportPath\n  }\n}];"
      },
