    {
      "parameters": {
        "jsCode": "const exceptions = $input.first().json.exceptions || [];\nconst totalTrades = exceptions.length;\nconst matched = exceptions.filter(e => e.exception_type === \"Field Mismatch\").length;\nconst unmatched = totalTrades - matched;\nconst highSeverity = exceptions.filter(e => e.severity === \"High\").length;\nconst lowSeverity = exceptions.filter(e => e.severity === \"Low\").length;\n\nreturn [{\n  json: {\n    total_trades: totalTrades,\n    matched_trades: matched,\n    unmatched_trades: unmatched,\n    high_severity_count: highSeverity,\n    low_severity_count: lowSeverity,\n    run_date: new Date().toISOString().split(\"T\")[0]\n  }\n}];"
      },
      "id": "5d94be77-972a-4029-a380-1ab2437f5fa7",
      "name": "Calculate Summary Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2480,
        784
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "<__PLACEHOLDER_VALUE__https://api.powerbi.com/v1.0/myorg/datasets/{dataset-id}/rows?key={api-key}__>",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"rows\": [{ \"run_date\": $json.run_date, \"total_trades\": $json.total_trades, \"matched\": $json.matched_trades, \"unmatched\": $json.unmatched_trades, \"high_severity\": $json.high_severity_count }] } }}",
        "options": {}
      },
      "id": "5d491065-233c-4d7d-851e-dd9e27044e32",
