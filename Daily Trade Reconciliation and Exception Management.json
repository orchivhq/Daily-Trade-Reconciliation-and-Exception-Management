        "subject": "={{ \"Daily Trade Reconciliation - \" + $now.toFormat(\"MMMM d, yyyy\") }}",
        "html": "={{ \"<h2>Daily Trade Reconciliation Summary</h2>\" +\n\"<p><strong>Run Date:</strong> \" + $(\"Calculate Summary Metrics\").item.json.run_date + \"</p>\" +\n\"<p><strong>Total Trades Reviewed:</strong> \" + $(\"Calculate Summary Metrics\").item.json.total_trades + \"</p>\" +\n\"<p><strong>Matched Trades:</strong> \" + $(\"Calculate Summary Metrics\").item.json.matched_trades + \"</p>\" +\n\"<p><strong>Unmatched Trades:</strong> \" + $(\"Calculate Summary Metrics\").item.json.unmatched_trades + \"</p>\" +\n\"<p><strong>High Severity Exceptions:</strong> \" + $(\"Calculate Summary Metrics\").item.json.high_severity_count + \"</p>\" +\n\"<p><strong>Low Severity Exceptions:</strong> \" + $(\"Calculate Summary Metrics\").item.json.low_severity_count + \"</p>\" +\n\"<p>Please review the attached exception report for details.</p>\" }}",
