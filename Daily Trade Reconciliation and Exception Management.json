      ]
    },
    {
      "parameters": {},
      "id": "cf65c963-00a6-4d4b-b09a-bc95458ef823",
      "name": "Merge Comparison and Duplicates",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        1808,
        736
      ]
    },
    {
      "parameters": {
        "jsCode": "const sqlRecords = $input.all().filter(item => item.json.SourceSystem === \"SQL_SERVER\");\nconst excelRecords = $input.all().filter(item => item.json.SourceSystem === \"EXCEL\");\nconst exceptions = [];\nconst reconDate = new Date().toISOString().split(\"T\")[0];\nconst QUANTITY_TOLERANCE = 0.0001;\nconst PRICE_TOLERANCE = 0.000001;\nconst NET_AMOUNT_TOLERANCE = 0.01;\nconst HIGH_NET_AMOUNT_THRESHOLD = 10000;\n\nconst sqlMap = new Map();\nfor (const item of sqlRecords) {\n  sqlMap.set(item.json.ReconciliationKey, item.json);\n}\n\nconst excelMap = new Map();\nfor (const item of excelRecords) {\n  excelMap.set(item.json.ReconciliationKey, item.json);\n}\n\nfor (const [key, sqlRec] of sqlMap) {\n  if (!excelMap.has(key)) {\n    exceptions.push({\n      ReconciliationDate: reconDate,\n      TradeDate: sqlRec.TradeDate,\n      TradeID: sqlRec.TradeID,\n      Account: sqlRec.Account,\n      SecurityID: sqlRec.SecurityID,\n      SourceSystem: \"SQL_SERVER\",\n      ExceptionType: \"MISSING_IN_EXCEL\",\n      SQLServerValue: `Q:${sqlRec.Quantity} P:${sqlRec.Price} N:${sqlRec.NetAmount}`,\n      ExcelValue: \"N/A\",\n      Difference: \"N/A\",\n      Severity: \"High\",\n      Status: \"Open\"\n    });\n  } else {\n    const excelRec = excelMap.get(key);\n    const qtyDiff = Math.abs(sqlRec.Quantity - excelRec.Quantity);\n    const priceDiff = Math.abs(sqlRec.Price - excelRec.Price);\n    const netDiff = Math.abs(sqlRec.NetAmount - excelRec.NetAmount);\n    \n    if (qtyDiff > QUANTITY_TOLERANCE) {\n      exceptions.push({\n        ReconciliationDate: reconDate,\n        TradeDate: sqlRec.TradeDate,\n        TradeID: sqlRec.TradeID,\n        Account: sqlRec.Account,\n        SecurityID: sqlRec.SecurityID,\n        SourceSystem: \"BOTH\",\n        ExceptionType: \"QUANTITY_MISMATCH\",\n        SQLServerValue: sqlRec.Quantity,\n        ExcelValue: excelRec.Quantity,\n        Difference: qtyDiff.toFixed(4),\n        Severity: \"High\",\n        Status: \"Open\"\n      });\n    }\n    \n    if (priceDiff > PRICE_TOLERANCE) {\n      exceptions.push({\n        ReconciliationDate: reconDate,\n        TradeDate: sqlRec.TradeDate,\n        TradeID: sqlRec.TradeID,\n        Account: sqlRec.Account,\n        SecurityID: sqlRec.SecurityID,\n        SourceSystem: \"BOTH\",\n        ExceptionType: \"PRICE_MISMATCH\",\n        SQLServerValue: sqlRec.Price,\n        ExcelValue: excelRec.Price,\n        Difference: priceDiff.toFixed(6),\n        Severity: \"Medium\",\n        Status: \"Open\"\n      });\n    }\n    \n    if (netDiff > NET_AMOUNT_TOLERANCE) {\n      const severity = netDiff > HIGH_NET_AMOUNT_THRESHOLD ? \"High\" : \"Medium\";\n      exceptions.push({\n        ReconciliationDate: reconDate,\n        TradeDate: sqlRec.TradeDate,\n        TradeID: sqlRec.TradeID,\n        Account: sqlRec.Account,\n        SecurityID: sqlRec.SecurityID,\n        SourceSystem: \"BOTH\",\n        ExceptionType: \"NET_AMOUNT_MISMATCH\",\n        SQLServerValue: sqlRec.NetAmount,\n        ExcelValue: excelRec.NetAmount,\n        Difference: netDiff.toFixed(2),\n        Severity: severity,\n        Status: \"Open\"\n      });\n    }\n  }\n}\n\nfor (const [key, excelRec] of excelMap) {\n  if (!sqlMap.has(key)) {\n    exceptions.push({\n      ReconciliationDate: reconDate,\n      TradeDate: excelRec.TradeDate,\n      TradeID: excelRec.TradeID,\n      Account: excelRec.Account,\n      SecurityID: excelRec.SecurityID,\n      SourceSystem: \"EXCEL\",\n      ExceptionType: \"MISSING_IN_SQL_SERVER\",\n      SQLServerValue: \"N/A\",\n      ExcelValue: `Q:${excelRec.Quantity} P:${excelRec.Price} N:${excelRec.NetAmount}`,\n      Difference: \"N/A\",\n      Severity: \"High\",\n      Status: \"Open\"\n    });\n  }\n}\n\nreturn exceptions.map(e => ({ json: e }));"
      },
