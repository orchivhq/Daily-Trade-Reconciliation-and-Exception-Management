    {
      "parameters": {
        "jsCode": "const allRecords = $input.all();\nconst duplicateMap = new Map();\nconst duplicates = [];\nconst reconDate = new Date().toISOString().split(\"T\")[0];\n\nfor (const item of allRecords) {\n  const key = item.json.ReconciliationKey + \"|\" + item.json.SourceSystem;\n  if (duplicateMap.has(key)) {\n    duplicateMap.set(key, duplicateMap.get(key) + 1);\n  } else {\n    duplicateMap.set(key, 1);\n  }\n}\n\nfor (const item of allRecords) {\n  const key = item.json.ReconciliationKey + \"|\" + item.json.SourceSystem;\n  if (duplicateMap.get(key) > 1) {\n    duplicates.push({\n      ReconciliationDate: reconDate,\n      TradeDate: item.json.TradeDate,\n      TradeID: item.json.TradeID,\n      Account: item.json.Account,\n      SecurityID: item.json.SecurityID,\n      SourceSystem: item.json.SourceSystem,\n      ExceptionType: \"DUPLICATE_TRADE\",\n      SQLServerValue: item.json.SourceSystem === \"SQL_SERVER\" ? `Q:${item.json.Quantity} P:${item.json.Price} N:${item.json.NetAmount}` : \"N/A\",\n      ExcelValue: item.json.SourceSystem === \"EXCEL\" ? `Q:${item.json.Quantity} P:${item.json.Price} N:${item.json.NetAmount}` : \"N/A\",\n      Difference: \"Duplicate\",\n      Severity: \"Medium\",\n      Status: \"Open\"\n    });\n  }\n}\n\nreturn duplicates.map(d => ({ json: d }));"
      },
      "id": "641e73f0-0065-4a73-9210-6e1a954e3f18",
      "name": "Identify Duplicates",
      "type": "n8n-nodes-base.code",
